{
  "name": "memact-capture",
  "private": true,
  "version": "0.0.0",
  "description": "Memact capture layer for app/site signals, optional extension capture, imports, and approved activity events.",
  "main": "./src/index.mjs",
  "exports": {
    ".": "./src/index.mjs"
  },
  "license": "MIT",
  "type": "module",
  "keywords": [
    "capture",
    "signals",
    "evidence",
    "browser-extension",
    "personalization"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Memact/Capture.git"
  },
  "homepage": "https://github.com/Memact/Capture",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "postinstall": "node scripts/sync-vendors.mjs",
    "sync-vendors": "node scripts/sync-vendors.mjs",
    "check": "node scripts/check.mjs && node --test",
    "test": "node --test",
    "build": "node scripts/package-extension.mjs",
    "device-helper": "node native-helper/src/helper.mjs",
    "device-helper:once": "node native-helper/src/helper.mjs --once --json",
    "device-helper:check": "npm --prefix native-helper run check",
    "package-extension": "node scripts/package-extension.mjs"
  },
  "dependencies": {
    "dexie": "^4.2.1",
    "flexsearch": "^0.8.212",
    "pdfjs-dist": "^5.4.149"
  },
  "devDependencies": {
    "esbuild": "^0.27.0"
  }
}
