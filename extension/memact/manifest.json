{
  "manifest_version": 3,
  "name": "Memact",
  "version": "0.0.0",
  "version_name": "v0.0",
  "description": "Capture consumed web activity for Memact citation and answer engines.",
  "icons": {
    "16": "icons/memact_16.png",
    "32": "icons/memact_32.png",
    "48": "icons/memact_48.png",
    "128": "icons/memact_128.png"
  },
  "permissions": ["tabs", "windows", "scripting", "storage", "unlimitedStorage", "webNavigation", "downloads", "history"],
  "host_permissions": [
    "<all_urls>",
    "http://localhost/*",
    "https://localhost/*",
    "http://127.0.0.1/*",
    "https://127.0.0.1/*",
    "http://0.0.0.0/*",
    "https://0.0.0.0/*",
    "https://memact.com/*",
    "https://www.memact.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self';"
  },
  "action": {
    "default_title": "Memact | Capture Evidence",
    "default_icon": {
      "16": "icons/memact_16.png",
      "32": "icons/memact_32.png",
      "48": "icons/memact_48.png",
      "128": "icons/memact_128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["bridge.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["Readability.js", "embed-worker.js", "page-api.js", "vendor/transformers.min.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
